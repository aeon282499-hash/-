# ========================================
# Instagram自動アフィリエイト - 環境変数設定
# このファイルを .env にコピーして値を入力してください
# ========================================

# ----------------------------------------
# Claude API（台本生成）
# https://console.anthropic.com/ で取得
# ----------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------
# ElevenLabs（ナレーション音声生成）
# https://elevenlabs.io/app/settings/api-keys で取得
# ----------------------------------------
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Voice IDは ElevenLabs の Voice Library から選択
# 日本語対応のおすすめ: eleven_multilingual_v2 モデルで任意のVoice
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ----------------------------------------
# Instagram（投稿）
# Meta Business Suite > 設定 > API で取得
# Instagram Business Account が必要
# ----------------------------------------
INSTAGRAM_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INSTAGRAM_BUSINESS_ACCOUNT_ID=000000000000000

# ----------------------------------------
# LINE Messaging API（完了通知）
# https://developers.line.biz/console/ でチャネル作成
# ----------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 通知先ユーザーID（LINE Official Account Managerの友だち一覧から確認）
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------
# AWS S3 / Cloudflare R2（動画ホスティング）
# Instagram Graph API が動画URLからダウンロードするため公開URLが必要
# ----------------------------------------
S3_BUCKET=your-bucket-name
S3_REGION=ap-northeast-1
S3_ACCESS_KEY=AKIAxxxxxxxxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Cloudflare R2 の場合は以下を設定:
# S3_ENDPOINT_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
S3_ENDPOINT_URL=
# CloudFront等で独自ドメインを使う場合:
S3_PUBLIC_BASE_URL=https://your-cdn-domain.com

# ----------------------------------------
# 投稿設定
# ----------------------------------------
POSTS_PER_DAY=3
