# ── KabuAI clone — 環境変数テンプレート ───────────────────────────────
# このファイルを kabuai/.env にコピーして値を埋める。.env はコミットしない。

# J-Quants V2 (既存の親プロジェクトと同じキーでよい)
# 親 my-first-project/.env で使っている JQUANTS_API_KEY をそのまま流用可。
JQUANTS_API_KEY=
# 自己署名/社内プロキシ環境で SSL 検証を切る場合のみ false
JQUANTS_VERIFY_SSL=true

# データソース選択: jquants_cache(既定/親pklを再利用) | jquants_api(都度取得) | stooq | yfinance
KABUAI_DATA_SOURCE=jquants_cache

# AI 要約バッチ用 LLM (フェーズ6・警戒メモ生成)
# 切替: gemini | groq | ollama / 空(or off,none,rule)＝LLM不使用＝指標ベースの自動メモのみ
# キー未設定や呼び出し失敗時も自動で rule(決定論メモ) にフォールバックするので必須ではない。
KABUAI_LLM_PROVIDER=
# 上位何銘柄まで LLM で生成するか（残りは rule・無料枠とCI時間を抑えるため既定24）
KABUAI_AI_LLM_TOP=24
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
